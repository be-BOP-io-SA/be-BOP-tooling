#
# Per-tenant be-BOP application config — managed by multi-tenant tooling.
# tooling-fingerprint: @template_revision@
#
# Installed at /etc/be-BOP/<tenant>/config.env, mode 0640, root-owned but
# group-readable by the dynamic systemd user via supplementary read access.
# The bebop@<tenant>.service unit loads it as EnvironmentFile=.
#
# Custom operator-managed entries below the scissor marker (>8) are preserved
# across re-runs of add-tenant.sh / upgrade-tenant.sh. Anything ABOVE the
# marker is overwritten on every run.
#
# Substitution placeholders (all replaced by add-tenant.sh):
#   @bebop_port@                local be-BOP port
#   @domain@                    <tenant>.<zone>                (public host)
#   @s3_domain@                 s3.<tenant>.<zone>             (public S3 host)
#   @mongodb_url@               full mongodb:// URL with creds
#   @mongodb_database@          per-tenant DB name (bebop_<tenant>)
#   @garage_bucket@             per-tenant bucket (bebop-<tenant>)
#   @garage_key_id@             access key id
#   @garage_key_secret@         access key secret
#   @phoenixd_port@             local phoenixd HTTP port
#   @phoenixd_http_password@    phoenixd HTTP password (read from phoenix.conf)
#   @template_revision@         template fingerprint

ADDRESS_HEADER=X-Forwarded-For
PORT=@bebop_port@
ORIGIN=https://@domain@
XFF_DEPTH=1

# === MongoDB (OVH Managed) ===
MONGODB_URL=@mongodb_url@
MONGODB_DB=@mongodb_database@

# === S3 / Garage ===
S3_REGION=garage
S3_ENDPOINT_URL=http://127.0.0.1:3900
PUBLIC_S3_ENDPOINT_URL=https://@s3_domain@
S3_BUCKET=@garage_bucket@
S3_KEY_ID=@garage_key_id@
S3_KEY_SECRET=@garage_key_secret@

# === Phoenixd (Lightning) ===
PHOENIXD_ENDPOINT_URL=http://127.0.0.1:@phoenixd_port@
PHOENIXD_HTTP_PASSWORD=@phoenixd_http_password@

# ------------------------ >8 ------------------------
# Put your custom configuration (even new environment variables) after this line.
# Anything ABOVE this marker is overwritten on every re-run of add-tenant.sh
# or upgrade-tenant.sh; everything BELOW is preserved.
