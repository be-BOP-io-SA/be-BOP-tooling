#
# Global secrets for be-BOP multi-tenant tooling.
# Install at /etc/be-BOP-tooling/secrets.env with mode 0600 owned by root.
#
# Loaded by: host-bootstrap.sh, add-tenant.sh, remove-tenant.sh, upgrade-*.sh
# Never log raw values — see lib/log.sh:mask_secrets.

# === OVH API ===
# Public API credentials. Generate at https://api.ovh.com/createToken/ with
# rights to manage DNS zones and (if applicable) the Public Cloud Mongo
# cluster.
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=

# DNS zone managed by OVH for tenant sub-domains (e.g. pvh-labs.com).
OVH_DNS_ZONE=pvh-labs.com

# === OVH Managed MongoDB ===
# Public Cloud project that hosts the Managed Database service. Found in the
# OVH manager URL: /manager/public-cloud/#/pci/projects/<this-uuid>
OVH_CLOUD_PROJECT_ID=

# UUID of the Mongo cluster within that project (Public Cloud > Databases >
# your cluster > General information).
OVH_MONGO_CLUSTER_ID=

# Mongo connection endpoint exposed by the cluster. host is typically of the
# form mongodb-<id>.database.cloud.ovh.net; port is usually 27017.
OVH_MONGO_ENDPOINT_HOST=
OVH_MONGO_ENDPOINT_PORT=27017

# === SFTP backup destination ===
# Used by remove-tenant.sh --archive to upload encrypted tenant archives.
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
# Either a literal password or an absolute path to an SSH private key.
# Prefer a key path on production hosts.
SFTP_PASSWORD_OR_KEY_PATH=
SFTP_REMOTE_PATH=

# Symmetric key used to encrypt archive bundles before SFTP upload.
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# === SMTP notifications ===
# Used to alert the support team on failed mutations (add/remove/upgrade).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# === Zulip notifications ===
# Bot credentials for posting alerts and success notices to a stream.
ZULIP_SITE=
ZULIP_BOT_EMAIL=
ZULIP_BOT_API_KEY=
ZULIP_STREAM=
ZULIP_TOPIC=

# === Uptime Kuma ===
# Used by add-tenant.sh / remove-tenant.sh to register/unregister monitors.
UPTIME_KUMA_URL=
UPTIME_KUMA_API_KEY=
