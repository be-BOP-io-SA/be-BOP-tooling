#
# Global secrets for be-BOP multi-tenant tooling.
# Install at /etc/be-BOP-tooling/secrets.env with mode 0600 owned by root.
#
# Loaded by: host-bootstrap.sh, add-tenant.sh, remove-tenant.sh, upgrade-*.sh
# Never log raw values — see lib/log.sh:mask_secrets.

# === OVH API ===
# Public API credentials. Generate at https://eu.api.ovh.com/createToken/ with
# rights to manage the DNS zone (used for DNS A records + Let's Encrypt DNS-01).
# Required scopes: GET/POST/DELETE on /domain/zone/<zone>/* and GET on /me.
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=

# DNS zone managed by OVH for tenant sub-domains (e.g. pvh-labs.com).
OVH_DNS_ZONE=pvh-labs.com

# Note: MongoDB is now hosted locally per-tenant (one mongod per tenant on
# 127.0.0.1, see templates/mongod@.service). No external Mongo configuration
# is required.

# === SFTP backup destination ===
# Used by remove-tenant.sh --archive to upload encrypted tenant archives.
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
# Either a literal password or an absolute path to an SSH private key.
# Prefer a key path on production hosts.
SFTP_PASSWORD_OR_KEY_PATH=
SFTP_REMOTE_PATH=

# Symmetric key used to encrypt archive bundles before SFTP upload.
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# === SMTP notifications ===
# Used to alert the support team on failed mutations (add/remove/upgrade).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# === Zulip notifications ===
# Bot credentials for posting alerts and success notices to a stream.
ZULIP_SITE=
ZULIP_BOT_EMAIL=
ZULIP_BOT_API_KEY=
ZULIP_STREAM=
ZULIP_TOPIC=

# === Uptime Kuma ===
# Used by add-tenant.sh / remove-tenant.sh to register/unregister monitors.
# Kuma runs locally in Docker on the same VDS (bound to 127.0.0.1:8810 by
# host-bootstrap.sh); no edit needed unless you overrode UPTIME_KUMA_HOST_PORT.
# UPTIME_KUMA_API_KEY is reserved for Kuma 2.x REST API; leave empty for now.
UPTIME_KUMA_URL=http://localhost:8810
UPTIME_KUMA_API_KEY=
