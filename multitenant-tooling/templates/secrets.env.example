#
# Global secrets for be-BOP multi-tenant tooling.
# Install at /etc/be-BOP-tooling/secrets.env with mode 0600 owned by root.
#
# Loaded by: host-bootstrap.sh, add-tenant.sh, remove-tenant.sh, upgrade-*.sh
# Never log raw values — see lib/log.sh:mask_secrets.
#
# Quoting convention: every value is wrapped in double quotes "" so that
# special characters (apostrophes, spaces, $, !, etc. in passwords) do not
# break `source secrets.env`. If your value itself contains a literal " ,
# escape it as \" inside the surrounding double quotes.

# === OVH API ===
# Public API credentials. Generate at https://eu.api.ovh.com/createToken/.
# Required scopes — strictly limited to the DNS zone configured below;
# the tooling never touches anything outside it. Replace 'pvh-labs.com'
# with the actual value you put in OVH_DNS_ZONE if different.
#     GET     /me
#     GET     /domain/zone/pvh-labs.com/*
#     POST    /domain/zone/pvh-labs.com/*
#     DELETE  /domain/zone/pvh-labs.com/*
OVH_APPLICATION_KEY=""
OVH_APPLICATION_SECRET=""
OVH_CONSUMER_KEY=""

# DNS zone managed by OVH for tenant sub-domains (e.g. pvh-labs.com).
OVH_DNS_ZONE="pvh-labs.com"

# Single Let's Encrypt operator account email shared across all tenants.
# Without this, add-tenant.sh falls back to the per-tenant --admin-email,
# which makes certbot register a NEW LE account for every tenant —
# Let's Encrypt rate-limits at "10 accounts / IP / 3h", so bulk
# onboarding (>10 tenants in 3h) hits a hard wall. Setting this once
# for the whole fleet keeps every cert under the same LE account and
# eliminates that risk.
LE_OPERATOR_EMAIL=""

# Note: MongoDB is now hosted locally per-tenant (one mongod per tenant on
# 127.0.0.1, see templates/mongod@.service). No external Mongo configuration
# is required.

# === SFTP backup destination ===
# Used by remove-tenant.sh --archive to upload encrypted tenant archives.
SFTP_HOST=""
SFTP_PORT="22"
SFTP_USER=""
# Either a literal password or an absolute path to an SSH private key.
# Prefer a key path on production hosts.
SFTP_PASSWORD_OR_KEY_PATH=""
SFTP_REMOTE_PATH=""

# Symmetric key used to encrypt archive bundles before SFTP upload.
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=""

# === SMTP notifications ===
# Used to alert the support team on failed mutations (add/remove/upgrade).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
SMTP_TO=""

# === Zulip notifications ===
# Bot credentials for posting alerts and success notices to a stream.
ZULIP_SITE=""
ZULIP_BOT_EMAIL=""
ZULIP_BOT_API_KEY=""
ZULIP_STREAM=""
ZULIP_TOPIC=""

# === Uptime Kuma ===
# Kuma runs locally in Docker on the same VDS (127.0.0.1:8810 by default)
# and is fully managed by the tooling: host-bootstrap.sh auto-provisions
# the admin (creds saved to /etc/be-BOP-tooling/kuma-admin.env, mode 0600),
# wires the SMTP + Zulip notification channels from this file, and
# add-tenant.sh / remove-tenant.sh add/remove monitors via Socket.IO.
# Override only if you changed UPTIME_KUMA_HOST_PORT in host-bootstrap.sh.
UPTIME_KUMA_URL="http://localhost:8810"
